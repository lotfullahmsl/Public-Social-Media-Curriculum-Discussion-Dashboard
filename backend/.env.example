# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
DATABASE_NAME=twitter_graph_db

# Scraping Configuration
SCRAPING_INTERVAL_MINUTES=30
MAX_TWEETS_PER_SCRAPE=2000
RATE_LIMIT_DELAY=2

# Keywords for University Content
UNIVERSITY_KEYWORDS=university,college,exam,assignment,syllabus,course,student,professor,grade,semester,midterm,final,homework,project

# Kurdistan Region Universities - Public
PUBLIC_UNIVERSITIES=salahaddin university erbil,sue,duhok university,uod,duhok polytechnic university,koya university,university of sulaimani,university of raparin,university of halabja,university of zakho,sulaimani polytechnic university

# Kurdistan Region Universities - Private/International  
PRIVATE_UNIVERSITIES=university of kurdistan hewler,ukh,american university of iraq sulaimani,auis,american university of kurdistan,auk,komar university,university of human development,uhd,catholic university erbil,cue,lebanese french university,lfu,cihan university,nawroz university

# University-specific Keywords
UNIVERSITY_SPECIFIC_KEYWORDS=salahaddin,sue,duhok,uod,koya,sulaimani,raparin,halabja,zakho,ukh,auis,auk,komar,uhd,cue,lfu,cihan,nawroz